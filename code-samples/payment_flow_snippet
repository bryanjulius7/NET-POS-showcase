    return Row(
      children: [
        _Metric(label: 'Amount Due', value: amountDue, primary: true),
        _Metric(label: 'Paid', value: paid),
        _Metric(label: 'Remaining', value: remaining),
        _Metric(label: 'Change', value: change),
