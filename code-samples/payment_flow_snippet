// Public showcase snippet extracted from NETech POS Payment Flow.
// Backend loading, production routing, and receipt integration removed.

import 'dart:math' as math;
import 'package:flutter/material.dart';

class PaymentFlowSnippet extends StatefulWidget {
  const PaymentFlowSnippet({super.key});

  @override
  State<PaymentFlowSnippet> createState() => _PaymentFlowSnippetState();
}

class _PaymentFlowSnippetState extends State<PaymentFlowSnippet> {
  final amountCtrl = TextEditingController(text: '10.00');
  final discountCtrl = TextEditingController(text: '0.00');

  String selectedMethod = 'cash';

  final subtotal = 8.40;

  double get discount {
    final raw = double.tryParse(discountCtrl.text.trim()) ?? 0;
    return raw.clamp(0, subtotal).toDouble();
  }

  double get total => subtotal - discount;

  double get tendered {
    return double.tryParse(amountCtrl.text.trim()) ?? 0;
  }

  double get change {
    if (selectedMethod != 'cash') return 0;
    return math.max(0, tendered - total);
  }

  bool get canConfirm {
    if (selectedMethod != 'cash') return true;
    return tendered >= total;
  }

  @override
  void dispose() {
    amountCtrl.dispose();
    discountCtrl.dispose();
    super.dispose();
  }

  void setQuickAmount(double value) {
    FocusScope.of(context).unfocus();
    amountCtrl.text = value.toStringAsFixed(2);
    setState(() {});
  }

  @override
  Widget build(BuildContext context) {
    final saleCard = _SaleSummaryCard(
      subtotal: subtotal,
      discount: discount,
      total: total,
    );

    final paymentPanel = _PaymentPanel(
      selectedMethod: selectedMethod,
      amountCtrl: amountCtrl,
      discountCtrl: discountCtrl,
      change: change,
      canConfirm: canConfirm,
      onMethodChanged: (method) {
        setState(() {
          selectedMethod = method;
          if (method != 'cash') {
            amountCtrl.text = total.toStringAsFixed(2);
          }
        });
      },
      onQuickAmount: setQuickAmount,
      onSplitPayment: () {
        showDialog(
          context: context,
          builder: (_) => SplitPaymentDemoDialog(total: total),
        );
      },
      onChanged: () => setState(() {}),
    );

    return LayoutBuilder(
      builder: (context, c) {
        final isWide = c.maxWidth >= 900;

        if (!isWide) {
          return Column(
            children: [
              Expanded(flex: 4, child: saleCard),
              const SizedBox(height: 12),
              Expanded(flex: 6, child: paymentPanel),
            ],
          );
        }

        return Row(
          children: [
            SizedBox(width: 360, child: saleCard),
            const SizedBox(width: 14),
            Expanded(child: paymentPanel),
          ],
        );
      },
    );
  }
}

class _SaleSummaryCard extends StatelessWidget {
