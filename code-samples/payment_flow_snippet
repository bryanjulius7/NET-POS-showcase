class SplitPaymentDemoDialog extends StatefulWidget {
  const SplitPaymentDemoDialog({super.key, required this.total});

  final double total;

  @override
  State<SplitPaymentDemoDialog> createState() => _SplitPaymentDemoDialogState();
}

class _SplitPaymentDemoDialogState extends State<SplitPaymentDemoDialog> {
  final List<_TenderLine> lines = [
    _TenderLine(method: 'Cash', amount: 0),
    _TenderLine(method: 'Card', amount: 0),
  ];

  double get paid => lines.fold(0, (sum, l) => sum + l.amount);
  double get remaining => math.max(0, widget.total - paid);
  double get change => math.max(0, paid - widget.total);

  @override
  Widget build(BuildContext context) {
    return Dialog(
      insetPadding: const EdgeInsets.all(24),
      child: ConstrainedBox(
        constraints: const BoxConstraints(maxWidth: 860),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              _SplitSummaryBar(
                amountDue: widget.total,
                paid: paid,
                remaining: remaining,
                change: change,
              ),
              const SizedBox(height: 12),
              for (int i = 0; i < lines.length; i++) ...[
                _TenderCard(
                  line: lines[i],
                  onAmountChanged: (v) {
                    setState(() => lines[i].amount = v);
                  },
                  onFillRemaining: () {
                    setState(() => lines[i].amount += remaining);
                  },
                ),
                const SizedBox(height: 10),
              ],
              Row(
                children: [
                  OutlinedButton.icon(
                    onPressed: () {
                      setState(() {
                        lines.add(_TenderLine(method: 'E-Wallet', amount: 0));
                      });
                    },
                    icon: const Icon(Icons.add),
                    label: const Text('Add payment'),
                  ),
                  const Spacer(),
                  FilledButton(
                    onPressed: remaining <= 0 ? () => Navigator.pop(context) : null,
                    child: const Text('Confirm Split Payment'),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

